{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=taskflow.db"
  },
  "AllowedOrigins": [],
  "JwtSettings": {
    "SecretKey": "TaskFlowSuperSecretKeyThatIsAtLeast32CharactersLong!",
    "Issuer": "TaskApi",
    "Audience": "TaskApiUsers",
    "ExpirationMinutes": 60
  }
}
